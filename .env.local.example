# ─────────────────────────────────────────────────────────────
# Tripcoord Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# Google Maps Platform
# Get your key at: https://console.cloud.google.com/google/maps-apis
# Enable these APIs: Places API, Maps JavaScript API, Directions API, Geocoding API
# Restrict the key: HTTP referrers for NEXT_PUBLIC_, server IPs for the server key
#
# GOOGLE_MAPS_KEY is server-side only (used in API routes — never exposed to browser)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY is client-side (used to render the map embed)
GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Without a key, the app runs in DEMO MODE:
# - Place search returns curated Iceland destinations
# - Place details return real-looking mock data (ratings, hours, etc.)
# - Everything still works — just no live Google data

# Anthropic (AI itinerary generation)
# Get your key at: https://console.anthropic.com/settings/keys
# Without this key, the Trip Wizard falls back to the demo trip (trip_1)
ANTHROPIC_API_KEY=

# ─── Future integrations ──────────────────────────────────────

# Supabase (database + auth + real-time)
# Get your keys at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (alternative map renderer — better styling, generous free tier)
# Get your token at: https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=

# Yelp Fusion (restaurant reviews + photos)
# Get your key at: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# Foursquare Places (activity + venue data)
# Get your key at: https://location.foursquare.com/developer
FOURSQUARE_API_KEY=

# OpenWeatherMap (live weather for itinerary days)
# Get your key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=
