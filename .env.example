# ─── AI ──────────────────────────────────────────────────────────────────────
# Required for AI itinerary generation, layover planner, phrasebook, and
# transport confirmation parser. Get yours at console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Supabase ────────────────────────────────────────────────────────────────
# Database, auth, storage, realtime. Create a project at supabase.com and copy
# from Project Settings → API. The service-role key bypasses RLS — never
# expose it to the client; it lives only in server-side code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Server-side key — powers Places search, autocomplete, and destination details
# Client-side key — powers the live map view on the itinerary page
# Both keys can be the same key restricted to the right APIs.
# Create at console.cloud.google.com → APIs & Services → Credentials
# Required APIs: Maps JavaScript API, Places API, Geocoding API
GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Subscriptions + Trip Pass checkout. Use test keys (sk_test_..., pk_test_...)
# locally; swap to live keys at launch. Webhook secret is the signing secret
# from your Stripe → Webhooks endpoint config.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
# Powers invite emails, lifecycle drips, password resets. Without SENDGRID_API_KEY
# the /api/cron/lifecycle-emails route returns 500 daily. FROM_EMAIL must be a
# verified sender (Single Sender Verification or Domain Authentication).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ─── SMS (Twilio) ────────────────────────────────────────────────────────────
# Powers SMS trip invites. Without these the SMS path 503s; email invites
# still work. Trial accounts can only send to verified numbers — upgrade
# to Pay-As-You-Go + complete A2P 10DLC registration before public launch.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for absolute links in emails, share links, OAuth redirects, etc.
# Set to http://localhost:3000 for local dev and https://your-domain for prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron auth ───────────────────────────────────────────────────────────────
# Vercel cron sends this as `Authorization: Bearer ${CRON_SECRET}` to
# /api/cron/*. Any long random string — generate with `openssl rand -hex 32`.
# Without it set, all four cron routes return 500 daily (reset-ai-credits,
# expire-venue-cache, preferences-fallback, lifecycle-emails).
CRON_SECRET=

# ─── Preview gate (optional) ─────────────────────────────────────────────────
# Powers the coming-soon `?preview=<value>` bypass. Cookie persists 90 days
# once set. Rotate before public launch since the value lives in middleware.
PREVIEW_SECRET=

# ─── Photos (optional) ───────────────────────────────────────────────────────
# Unsplash powers dynamic destination photos on trip cards. Without it,
# trip cards fall back to a gradient placeholder. Free tier on Unsplash
# allows 50 req/hr — fine for our scale.
UNSPLASH_ACCESS_KEY=

# ─── Airtable (optional) ─────────────────────────────────────────────────────
# Powers the integration voting panel in Settings — aggregates votes and
# comments across all users. The panel works without these (localStorage only).
# Create a base at airtable.com, then get a token at airtable.com/create/tokens
# Table name should be: Integration Feedback
# Fields: Integration (text), Type (single select), Comment (long text), Timestamp (date)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Integration Feedback
